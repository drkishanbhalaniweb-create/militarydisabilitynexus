# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=YOUR_SUPABASE_URL
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY
# Server-only: Required for form submissions (API routes). Find at: Supabase Dashboard → Settings → API → service_role key
SUPABASE_SERVICE_ROLE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY

# Stripe Configuration
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=YOUR_STRIPE_PUBLISHABLE_KEY

# Cal.com Configuration
NEXT_PUBLIC_CAL_URL_DISCOVERY=YOUR_CAL_URL_DISCOVERY
NEXT_PUBLIC_CAL_URL_CONSULTATION=YOUR_CAL_URL_CONSULTATION

# Optional: Meta Pixel
NEXT_PUBLIC_META_PIXEL_ID=YOUR_META_PIXEL_ID

# Optional: Visual Edits (for development)
NEXT_PUBLIC_ENABLE_VISUAL_EDITS=true
NEXT_PUBLIC_ENABLE_HEALTH_CHECK=false
